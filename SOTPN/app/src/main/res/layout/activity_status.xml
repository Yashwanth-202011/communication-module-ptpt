<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#F5F5F5">

    <!-- Title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Transaction Status"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#1A1A2E"
        android:layout_marginBottom="24dp" />

    <!-- Phase progress card -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PHASE PROGRESS"
                android:textSize="12sp"
                android:textColor="#999999"
                android:letterSpacing="0.1"
                android:layout_marginBottom="16dp" />

            <!-- Phase 1: Prepare -->
            <LinearLayout
                android:id="@+id/rowPhase1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/iconPhase1"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:text="○"
                    android:textSize="18sp"
                    android:textColor="#CCCCCC"
                    android:gravity="center"
                    android:layout_marginEnd="12dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Prepare"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A2E" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lock token + sign transaction"
                        android:textSize="12sp"
                        android:textColor="#999999" />

                </LinearLayout>

            </LinearLayout>

            <!-- Phase 2: Validate -->
            <LinearLayout
                android:id="@+id/rowPhase2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/iconPhase2"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:text="○"
                    android:textSize="18sp"
                    android:textColor="#CCCCCC"
                    android:gravity="center"
                    android:layout_marginEnd="12dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Validate"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A2E" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Signature + expiry + nonce checks"
                        android:textSize="12sp"
                        android:textColor="#999999" />

                </LinearLayout>

            </LinearLayout>

            <!-- Phase 3: Delay -->
            <LinearLayout
                android:id="@+id/rowPhase3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/iconPhase3"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:text="○"
                    android:textSize="18sp"
                    android:textColor="#CCCCCC"
                    android:gravity="center"
                    android:layout_marginEnd="12dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Verify"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A2E" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Gossip broadcast + conflict detection"
                        android:textSize="12sp"
                        android:textColor="#999999" />

                </LinearLayout>

            </LinearLayout>

            <!-- Phase 4: Commit -->
            <LinearLayout
                android:id="@+id/rowPhase4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/iconPhase4"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:text="○"
                    android:textSize="18sp"
                    android:textColor="#CCCCCC"
                    android:gravity="center"
                    android:layout_marginEnd="12dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Commit"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A2E" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Exchange ACK + finalize wallets"
                        android:textSize="12sp"
                        android:textColor="#999999" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Delay countdown card (visible only during Phase 3) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardDelay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:visibility="gone"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="VERIFICATION WINDOW"
                    android:textSize="12sp"
                    android:textColor="#999999"
                    android:letterSpacing="0.1" />

                <TextView
                    android:id="@+id/tvCountdown"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="10s"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A2E" />

            </LinearLayout>

            <ProgressBar
                android:id="@+id/delayProgressBar"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                android:progress="100"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/tvRiskLevel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Medium risk — standard verification"
                android:textSize="13sp"
                android:textColor="#666666" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Status message -->
    <TextView
        android:id="@+id/tvStatusMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Preparing transaction..."
        android:textSize="15sp"
        android:textColor="#333333"
        android:gravity="center"
        android:layout_marginBottom="16dp" />

    <!-- Spacer -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Cancel button -->
    <Button
        android:id="@+id/btnCancelStatus"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Cancel"
        android:textSize="16sp"
        android:backgroundTint="#F44336"
        android:textColor="#FFFFFF"
        app:cornerRadius="12dp" />

</LinearLayout>